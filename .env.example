# Fireworks AI (remote escalation path — these tokens COUNT toward score)
FIREWORKS_API_KEY=fw-your-key-here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Local vLLM server (tokens are FREE for scoring)
LOCAL_BASE_URL=http://localhost:8000/v1
LOCAL_MODEL=google/gemma-4-26B-A4B-it

# Allowed remote models (from the kickoff ALLOWED_MODELS announcement).
# Calling anything outside this list invalidates the submission.
ALLOWED_MODELS=minimax-m3,kimi-k2p7-code,gemma-4-31b-it,gemma-4-26b-a4b-it,gemma-4-31b-it-nvfp4

# Prefix applied to short model names when calling Fireworks.
REMOTE_MODEL_PREFIX=accounts/fireworks/models/

# Router tuning (the main scoring levers — sweep with eval/sweep.py)
CONSISTENCY_SAMPLES=5
CONSISTENCY_THRESHOLD=0.6

# Container I/O paths (per Track 1 spec)
INPUT_PATH=/input/tasks.json
OUTPUT_PATH=/output/results.json
